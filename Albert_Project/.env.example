# Copy this file to .env and fill in your API keys
# Never commit .env to version control

# ── AI API Keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-claude-key-here...
OPENAI_API_KEY=sk-...your-openai-key-here...

# ── Currency Conversion ─────────────────────────────────────────────────────
# EUR to USD exchange rate (update periodically)
EUR_USD_RATE=1.09

# ── Job Costing Defaults (can override per project in project_config.json) ──
GP_TARGET_PCT=0.35
COMMISSION_PCT=0.05
BOND_PCT=0.015
LOCAL_USE_TAX_PCT=0.075
OCEAN_FREIGHT_PER_CONTAINER=4500.00
INLAND_DELIVERY=1200.00
INSTALLATION_PER_CABINET=85.00
WAREHOUSING_PCT=0.02
MATERIAL_PROTECTION_PCT=0.005
INSURANCE_PCT=0.008
MISC_ALLOWANCE=500.00
CABINETS_PER_CONTAINER=220
