# Copy this file to .env and fill in your local keys.
# Never commit .env to version control.

# AI vision provider
# Primary path: OpenRouter -> Google Gemini vision models.
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...your-openrouter-key-here...

# Optional legacy/direct provider keys for experiments or older scripts.
GEMINI_API_KEY=AIza...your-gemini-key-here...
GROQ_API_KEY=gsk_...your-groq-key-here...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key-here...
OPENAI_API_KEY=sk-...your-openai-key-here...

# Demo mode lowers image resolution and prompt/output size for cheaper demos.
DEMO_MODE=false

# Currency conversion
EUR_USD_RATE=1.09

# Job costing defaults. Individual projects can override these in project_config.json.
GP_TARGET_PCT=0.35
COMMISSION_PCT=0.05
BOND_PCT=0.015
LOCAL_USE_TAX_PCT=0.075
OCEAN_FREIGHT_PER_CONTAINER=4500.00
INLAND_DELIVERY=1200.00
INSTALLATION_PER_CABINET=85.00
WAREHOUSING_PCT=0.02
MATERIAL_PROTECTION_PCT=0.005
INSURANCE_PCT=0.008
MISC_ALLOWANCE=500.00
CABINETS_PER_CONTAINER=220
